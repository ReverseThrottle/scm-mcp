# Palo Alto Networks Strata Cloud Manager credentials
# Obtain from: SCM > Settings > Service Accounts
SCM_CLIENT_ID=your_client_id_here
SCM_CLIENT_SECRET=your_client_secret_here
SCM_TSG_ID=your_default_tsg_id_here

# Optional named TSG aliases for multi-tenant use
# Pass the alias name (e.g. "PROD") as the tsg_id argument to any tool.
# Use scm_list_tsg_profiles to see all configured aliases.
# SCM_TSG_PROD=prod_tsg_id_here
# SCM_TSG_LAB=lab_tsg_id_here

# Per-TSG credentials (optional — overrides global SCM_CLIENT_ID/SECRET for that alias)
# SCM_TSG_PROD_CLIENT_ID=svc-api@<tsg_id>.iam.panserviceaccount.com
# SCM_TSG_PROD_CLIENT_SECRET=your_secret_here
